<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HERO IMAGE + Tombol Back -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="260dp">

            <ImageView
                android:id="@+id/ivDetailKamera"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_placeholder"
                android:background="@color/primary"
                android:contentDescription="Foto kamera" />

            <!-- Gradient overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_bottom" />

            <!-- Tombol Back -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="16dp"
                android:src="@drawable/ic_back"
                android:background="@drawable/bg_btn_back"
                android:contentDescription="@string/back"
                app:tint="@color/text_white" />

            <!-- Nama + Badge overlay di bawah gambar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/tvDetailNama"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sony A7 IV"
                    android:textColor="@color/text_white"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDetailTipe"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mirrorless"
                    android:textColor="@color/text_white"
                    android:textSize="12sp"
                    android:background="@drawable/bg_badge_white"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>
        </FrameLayout>

        <!-- BODY KONTEN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/bg_card"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- Info Row: Resolusi & Sensor -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Resolusi -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_info_card"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📸 Resolusi"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvDetailResolusi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="33 MP"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <View android:layout_width="10dp" android:layout_height="1dp" />

                <!-- Sensor -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_info_card"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔲 Sensor"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvDetailSensor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full Frame"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Info Row: Video & Harga -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <!-- Video -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_info_card"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎥 Video"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvDetailVideo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4K 60fps"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <View android:layout_width="10dp" android:layout_height="1dp" />

                <!-- Harga -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_harga_card"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💰 Harga"
                        android:textColor="@color/accent_dark"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/tvDetailHarga"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 35 jt"
                        android:textColor="@color/accent_dark"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Deskripsi -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tentang Kamera Ini"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp" />

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@color/sony_gold"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvDetailDeskripsi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Deskripsi kamera akan tampil di sini..."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.6" />

            <!-- Fitur Unggulan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fitur Unggulan"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp" />

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@color/sony_gold"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvDetailFitur"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fitur unggulan akan tampil di sini..."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.6" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
